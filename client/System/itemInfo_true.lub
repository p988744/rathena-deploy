if tbl then
	for id, name in pairs(zh_names) do
		if tbl[id] then
			tbl[id].identifiedDisplayName = name
			tbl[id].unidentifiedDisplayName = name
		end
	end
end

local function patch(id, name, desc)
	if tbl and tbl[id] then
		tbl[id].identifiedDisplayName = name
		tbl[id].unidentifiedDisplayName = name
		tbl[id].identifiedDescriptionName = desc
	end
end

