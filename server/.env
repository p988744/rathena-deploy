# ============================================================
# .env — rAthena VPS 部署設定
# ============================================================

# --- VPS 連線資訊 ---
SERVER_IP=127.0.0.1
SERVER_USER=ubuntu
SERVER_SSH_PORT=22
REMOTE_DIR=/opt/rathena

# --- 伺服器設定 ---
SERVER_NAME=最粗的感動

# --- 遊戲倍率 ---
# 100 = 1x（官方）, 500 = 5x, 1000 = 10x
BASE_EXP_RATE=5000
JOB_EXP_RATE=5000
DROP_RATE=5000
CARD_DROP_RATE=5000

# --- 資料庫設定 ---
DB_USER=ragnarok
DB_PASS=ragnarok
DB_NAME=ragnarok
DB_ROOT_PASS=ragnarok_root
DB_PORT_EXPOSE=3306

# --- 建置設定 ---
RATHENA_BRANCH=master
# 釘定穩定 commit（Feb 25, 2026），避免 Feb 26+ skill split 引發的 map-server segfault
# 設為空字串改用 RATHENA_BRANCH 最新版
RATHENA_COMMIT=f464a8b813f4
PACKETVER=20220406
BUILD_MODE=re
